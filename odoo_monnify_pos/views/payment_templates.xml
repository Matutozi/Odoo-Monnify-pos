<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="monnify_payment_status" inherit_id="payment.transaction_status">
        <xpath expr="//div[contains(@class, 'o_payment_status') ]" position="inside">
            <t t-if="tx.provider_code == 'monnify' and tx.monnify_account_number">
                <div class="alert alert-info mt-3">
                    <strong>Transfer Details</strong>
                    <div>Bank: <t t-esc="tx.monnify_bank_name or 'Monnify'"/></div>
                    <div>Account Number: <t t-esc="tx.monnify_account_number"/></div>
                    <div>Reference: <t t-esc="tx.monnify_payment_reference or tx.reference"/></div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
