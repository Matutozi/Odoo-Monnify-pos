<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="monnify_pos.MonnifyPopup">
        <!-- Dialog's own header/footer/padding are turned off so the popup can
             render its own branded header and action row (see monnify_popup.css). -->
        <Dialog header="false" footer="false" withBodyPadding="false"
                size="'md'" contentClass="'monnify-dialog'">
            <div class="monnify-popup">

                <!-- ============ WAITING ============ -->
                <t t-if="!ui.paid">
                    <div class="mn-head">
                        <span class="mn-mark"><i class="fa fa-credit-card" role="img" aria-label="Monnify"/></span>
                        <div class="mn-t">
                            <h1>Pay by Bank Transfer</h1>
                            <p>Powered by Monnify</p>
                        </div>
                        <button class="mn-x" t-on-click="onCancelClick" aria-label="Cancel">
                            <i class="fa fa-times"/>
                        </button>
                    </div>

                    <div class="mn-body">
                        <div class="mn-amount-wrap">
                            <div class="mn-label">Amount to transfer</div>
                            <div class="mn-amount mn-num" t-out="props.amount"/>
                        </div>

                        <div class="mn-panel">
                            <div class="mn-acct">
                                <div>
                                    <div class="mn-label" style="margin-bottom:.15rem">Account number</div>
                                    <div class="mn-n mn-num" t-out="props.accountNumber"/>
                                </div>
                                <button class="mn-copy" t-att-class="{ 'mn-copied': state.copied }" t-on-click="onCopy">
                                    <i t-att-class="state.copied ? 'fa fa-check' : 'fa fa-clone'"/>
                                    <span t-out="state.copied ? 'Copied' : 'Copy'"/>
                                </button>
                            </div>
                            <div class="mn-row">
                                <span class="mn-k">Bank</span>
                                <span class="mn-v" t-out="props.bankName"/>
                            </div>
                            <div class="mn-row">
                                <span class="mn-k">Account name</span>
                                <span class="mn-v" t-out="props.accountName"/>
                            </div>
                        </div>

                        <p class="mn-hint">
                            Send the <b>exact amount</b> to this one-time account.
                            This screen updates <b>automatically</b> the moment payment is received.
                        </p>

                        <div class="mn-status">
                            <span class="mn-listening">
                                <span class="mn-pulse"/>
                                <t t-esc="state.verifying ? 'Checking with Monnify…' : 'Listening for payment…'"/>
                            </span>
                            <span class="mn-expires" t-if="!expired">
                                Expires in <b class="mn-num" t-out="countdown"/>
                            </span>
                            <span class="mn-expires" t-else="">
                                <b>Expired</b>
                            </span>
                        </div>

                        <t t-if="state.hint">
                            <p class="mn-hint" t-out="state.hint"/>
                        </t>

                        <a t-if="props.checkoutUrl" class="mn-sandbox" target="_blank"
                           rel="noopener" t-att-href="props.checkoutUrl">
                            Sandbox test — open Monnify checkout
                        </a>
                    </div>

                    <div class="mn-foot">
                        <button class="mn-btn mn-primary" t-on-click="onVerifyClick"
                                t-att-disabled="state.verifying or expired">
                            <i class="fa fa-check-circle"/>
                            <span t-out="state.verifying ? 'Checking…' : 'Verify Payment'"/>
                        </button>
                        <button class="mn-btn mn-ghost" t-on-click="onCancelClick">Cancel</button>
                    </div>
                </t>

                <!-- ============ PAID ============ -->
                <t t-else="">
                    <div class="mn-paid">
                        <div class="mn-check"><i class="fa fa-check"/></div>
                        <h2>Payment received</h2>
                        <div class="mn-amt mn-num" t-out="props.amount"/>
                        <div class="mn-payer" t-if="ui.payerName">
                            from <b t-out="ui.payerName"/>
                        </div>
                        <div class="mn-done">Completing sale…</div>
                    </div>
                </t>

            </div>
        </Dialog>
    </t>

</templates>
