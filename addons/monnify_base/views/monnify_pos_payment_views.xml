<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_monnify_pos_payment_list" model="ir.ui.view">
        <field name="name">monnify.pos.payment.list</field>
        <field name="model">monnify.pos.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="monnify_tx_ref"/>
                <field name="pos_session_id"/>
                <field name="amount"/>
                <field name="amount_paid"/>
                <field name="state"/>
                <field name="paid_on"/>
            </list>
        </field>
    </record>

    <record id="action_monnify_pos_payment" model="ir.actions.act_window">
        <field name="name">Monnify Payments</field>
        <field name="res_model">monnify.pos.payment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
